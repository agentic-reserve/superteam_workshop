# Helius API Key (get from https://dashboard.helius.dev)
NEXT_PUBLIC_HELIUS_API_KEY=your_helius_api_key_here

# RPC URLs
NEXT_PUBLIC_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
NEXT_PUBLIC_DEVNET_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Network (mainnet-beta or devnet)
NEXT_PUBLIC_NETWORK=mainnet-beta
